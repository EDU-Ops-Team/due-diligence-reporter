# Wrike API
WRIKE_ACCESS_TOKEN=your_wrike_access_token_here

# Google OAuth (paths to credential files — set by setup.sh on MCP Hive)
GOOGLE_CLIENT_CONFIG=credentials/client_secrets.json
GOOGLE_TOKEN_FILE=.gcp-saved-tokens.json

# Google Doc template ID — the master DD report template (V3 primary)
# One-time setup: edit the template doc to add {{PLACEHOLDER}} tokens, then paste its ID here
DD_TEMPLATE_V3_GOOGLE_DOC_ID=your_google_doc_template_id_here
# Legacy fallback (optional during migration)
DD_TEMPLATE_V2_GOOGLE_DOC_ID=

# Google Drive root folder ID — parent folder containing all site folders
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_root_folder_id_here

# OpenAI (used for fuzzy site name matching when searching Wrike)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_FILENAME_MODEL=gpt-4o-mini
OPENAI_CONTENT_MODEL=gpt-4o-mini
OPENAI_SITE_MATCH_MODEL=gpt-4o-mini
ANTHROPIC_REPORT_MODEL=claude-sonnet-4-6
OPS_SKILLS_REPO_PATH=

# RayCon async hand-off — DDR pings /v1/jobs when a Block Plan lands in M1.
# RayCon writes raycon_scenario.json back into the same M1 folder; the
# raycon-followup workflow publishes the report Doc.
#
# Auth: RayCon's /v1/jobs is currently public under the /v1/* rollout (per
# RayCon team 2026-04-30) — no secret required to make calls work. When
# RAYCON_WEBHOOK_SECRET is set, DDR HMAC-SHA256-signs the raw body with it
# and sends X-RayCon-Signature, so the canonical signing path is exercised
# and ready for the day RayCon enables verification. Leave blank otherwise.
RAYCON_WEBHOOK_SECRET=
# Optional. Sent in X-RayCon-API-Key for the RayCon Firebase auth path,
# which is gated by RAYCON_REQUIRE_FIREBASE_AUTH=true on RayCon's side
# (currently disabled). Leave blank in production.
RAYCON_API_KEY=
# RAYCON_JOBS_URL defaults to https://raycon-api-dkxp2hji2q-uc.a.run.app/v1/jobs (optional override)

# Shovels.ai permit history API — DEPRECATED for DDR.
#
# The Shovels integration runs upstream now (AI SIR / source-evidence
# build), which supplies permit history risk flags directly to DDR via
# the ``permit_history.risk_flags`` token. DDR does not call Shovels
# during report generation and SHOVELS_API_KEY is NOT required.
#
# Leave both blank unless you explicitly need to invoke the legacy
# get_permit_history MCP tool (gated by DDR_ENABLE_SHOVELS=true).
DDR_ENABLE_SHOVELS=false
SHOVELS_API_KEY=
REBL_BASE_URL=https://rebl3.vercel.app

# Notifications
DD_REPORT_EMAIL_RECIPIENTS=
SIR_NOTIFICATION_RECIPIENTS=
CDS_NOTIFICATION_RECIPIENTS=
GLOBAL_EMAIL_CC=

# Inbox scanner labels
INBOX_SCAN_QUERY={to:edu.ops@trilogy.com cc:edu.ops@trilogy.com} has:attachment filename:pdf
INBOX_PROCESSED_LABEL=DD-Processed
INBOX_MANUAL_REVIEW_LABEL=DD-Manual-Review

# Inbox scanner — sender filtering
# Domains treated as internal (attachments from these senders are skipped)
INBOX_INTERNAL_SENDER_DOMAINS=trilogy.com
# Additional full addresses to treat as internal (service accounts, etc.)
INBOX_INTERNAL_SENDER_ADDRESSES=

# DD Dashboard aggregation + deploy
# Local path (relative to repo root) where sites.json is written after aggregation.
DASHBOARD_OUTPUT_PATH=dist/sites.json
# Optional: Drive folder to also receive a copy of sites.json for the team.
DASHBOARD_DRIVE_FOLDER_ID=
# Optional: GitHub repo (owner/name) the aggregator pushes sites.json to.
# When set, the aggregator runs `gh` to clone, overwrite, commit, and push.
DASHBOARD_REPO=
DASHBOARD_REPO_PATH=public/sites.json
DASHBOARD_REPO_BRANCH=main

# DD Dashboard live (Vercel) — used by recover_migration_wiped_sites.py and
# cleanup_phantom_recovery_slugs.py to issue authenticated POST/DELETE calls.
# Default in code is https://dd-dashboard-three.vercel.app — override with
# this env var to point at a preview deployment for end-to-end testing.
DASHBOARD_PUBLISH_URL=
# Bearer token shared with dd-dashboard's /api/sites/* endpoints. Required
# for any --apply run; recover/cleanup scripts hard-fail if missing in
# apply mode. Generate with: openssl rand -hex 32
# Set the same value in the dashboard repo's Vercel project secrets so
# both sides authenticate against the same token. Rotate by generating
# a new value, deploying it to dd-dashboard first, then updating here.
DASHBOARD_PUBLISH_SECRET=
